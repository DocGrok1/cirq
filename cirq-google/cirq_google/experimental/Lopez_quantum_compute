import numpy as np
import matplotlib.pyplot as plt
from qutip import Qobj, basis, sigmax, sigmay, sigmaz, tensor, mesolve, qeye, rand_dm_ginibre
from scipy.optimize import minimize

# ========================
# 1. Quantum Circuit & Parameters
# ========================
N_QUBITS = 2                  # Number of qubits (scalable)
STEPS = 250000                # Internal LGH steps per circuit evaluation
N_CYCLES = 200                # Number of circuit evaluations (optimization steps)

# Hamiltonian (simple transverse field Ising for demonstration)
H = tensor(sigmax(), sigmax()) + 0.5 * (tensor(sigmaz(), qeye(2)) + tensor(qeye(2), sigmaz()))

# Initial state (mixed state with noise)
rho0 = rand_dm_ginibre(2**N_QUBITS)  # Random mixed state

# Dissipation (decoherence)
c_ops = [0.05 * tensor(sigmax(), qeye(2)), 0.05 * tensor(qeye(2), sigmax())]  # Bit-flip noise

# Bus 300 map parameters
MAP_SIZE = 6.0
GRID_RES = 200
X, Y = np.meshgrid(np.linspace(-MAP_SIZE/2, MAP_SIZE/2, GRID_RES),
                   np.linspace(-MAP_SIZE/2, MAP_SIZE/2, GRID_RES))

# ========================
# 2. LGH Governance Core
# ========================
class LGHGovernance:
    def __init__(self):
        self.horizon_pressure = 0.976
        self.guarded_margin = 0.0238
        self.authority = 1.05
        self.rescue_window = 0.0562
        self.coherence = 0.5123
        self.meta_recursion_score = 0.0027

    def update(self, fidelity_delta):
        # Dissipation & obligation drain
        self.authority -= 0.001 * (1 - fidelity_delta)
        self.authority = np.clip(self.authority, 0.0, 1.5)

        # Horizon pressure
        self.horizon_pressure = 0.976 + 0.002 * (1 - self.guarded_margin)
        self.horizon_pressure = np.clip(self.horizon_pressure, 0.95, 0.99)

        # Rescue window
        if self.guarded_margin < 0.03:
            self.rescue_window = 0.0562 * (1 - self.guarded_margin / 0.03)
        else:
            self.rescue_window *= 0.95
        self.rescue_window = np.clip(self.rescue_window, 0.01, 0.15)

        # Margin (self-healing)
        self.guarded_margin += 0.01 * self.rescue_window * fidelity_delta
        self.guarded_margin = np.clip(self.guarded_margin, 0.01, 0.03)

        # Coherence recovery
        self.coherence += 0.05 * self.rescue_window * fidelity_delta
        self.coherence = np.clip(self.coherence, 0.5, 0.95)

        # Meta-recursion rise
        if self.guarded_margin > 0.021:
            self.meta_recursion_score += 0.0001 * self.coherence
        self.meta_recursion_score = np.clip(self.meta_recursion_score, 0.0, 0.5)

    def get_metrics(self):
        return {
            'horizon_pressure': self.horizon_pressure,
            'guarded_margin': self.guarded_margin,
            'authority': self.authority,
            'rescue_window': self.rescue_window,
            'coherence': self.coherence,
            'meta_recursion_score': self.meta_recursion_score
        }

# ========================
# 3. Quantum Circuit Ansatz (Variational)
# ========================
def variational_circuit(theta):
    # Simple 2-qubit ansatz (RY-RZ-CNOT)
    qc = Qobj(np.eye(4))
    for i in range(2):
        qc = qc * tensor(sigmay().rotate(theta[i*2]), qeye(2))  # RY
        qc = qc * tensor(sigmaz().rotate(theta[i*2+1]), qeye(2))  # RZ
    qc = qc * tensor(basis(2,0)*basis(2,0).dag() + basis(2,1)*basis(2,1).dag(), sigmax())  # CNOT-like
    return qc

# ========================
# 4. Main Simulation Loop
# ========================
def run_lgh_quantum_computing(n_cycles=N_CYCLES):
    lgh = LGHGovernance()
    rho = rho0.copy()
    metrics_history = []
    trajectory = []  # For Bus 300 map

    # Optimization parameters
    theta = np.random.uniform(0, 2*np.pi, 4)  # Initial variational parameters

    for cycle in range(n_cycles):
        # Variational circuit application
        U = variational_circuit(theta)
        rho = U * rho * U.dag()

        # Dissipation
        result = mesolve(H, rho, [0, 0.01], c_ops, [tensor(sigmaz(), qeye(2)), tensor(qeye(2), sigmaz())])
        rho = result.states[-1]

        # Fidelity delta (to ideal state)
        ideal_rho = basis(4, 0) * basis(4, 0).dag()  # Target Bell-like state
        fidelity_delta = (rho * ideal_rho).tr().real

        # LGH update
        lgh.update(fidelity_delta)
        metrics = lgh.get_metrics()
        metrics_history.append(metrics)

        # Trajectory on Bus 300 map (authority vs coherence deviation)
        trajectory.append((metrics['authority'] - 0.5, metrics['coherence'] - 0.5))

        # Fisher-Rao optimization (simple gradient step)
        def cost(theta):
            U = variational_circuit(theta)
            rho_new = U * rho0 * U.dag()
            return -fidelity_delta  # Maximize fidelity

        res = minimize(cost, theta, method='BFGS', options={'maxiter': 5})
        theta = res.x

        if cycle % 50 == 0:
            print(f"Cycle {cycle}: Coherence {metrics['coherence']:.4f}, Horizon Pressure {metrics['horizon_pressure']:.4f}, Margin {metrics['guarded_margin']:.4f}")

    return metrics_history, trajectory

# ========================
# 5. Run & Visualize
# ========================
metrics_history, trajectory = run_lgh_quantum_computing()

# Plot 1: LGH Metrics Over Time
metrics_keys = ['horizon_pressure', 'guarded_margin', 'authority', 'rescue_window', 'coherence', 'meta_recursion_score']
plt.figure(figsize=(12, 8))
for key in metrics_keys:
    values = [m[key] for m in metrics_history]
    plt.plot(values, label=key)
plt.xlabel('Cycle')
plt.ylabel('Value')
plt.title('LGH Metrics During Quantum Computing Simulation')
plt.grid(True)
plt.legend()
plt.show()

# Plot 2: Bus 300 Map Trajectory
plt.figure(figsize=(8, 8))
theta = np.linspace(0, 2*np.pi, 100)
for r, color in zip([3, 2.5, 2, 1.5, 1], ['blue', 'cyan', 'green', 'yellow', 'orange']):
    plt.plot(r * np.cos(theta), r * np.sin(theta), color=color, lw=2)
plt.text(0, 0, 'Habitable Core', ha='center', va='center', fontsize=12)
plt.text(2.8, 0, 'Governance Horizon', ha='center', va='center', fontsize=10, color='blue')

traj = np.array(trajectory)
plt.plot(traj[:, 0], traj[:, 1], 'k-', alpha=0.5, lw=1, label='Trajectory')

plt.xlabel('Authority Deviation')
plt.ylabel('Coherence Deviation')
plt.title('Bus 300 Map – Quantum Circuit Trajectory (Inward Migration)')
plt.grid(True)
